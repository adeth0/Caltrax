# Supabase project settings — Project Settings > API Keys in the Supabase dashboard.
# Current key format: publishable (client-safe) and secret (server-only),
# replacing the legacy anon/service_role naming.
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
# Server-only — never prefix with NEXT_PUBLIC_, never sent to the browser.
SUPABASE_SECRET_KEY="sb_secret_..."

# PostgreSQL — pooled connection (Supabase "Transaction" pooler, port 6543).
# Project Settings > Database > Connection string in the Supabase dashboard.
DATABASE_URL="postgresql://postgres.xxxx:password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"

# PostgreSQL — direct/unpooled connection (port 5432), used only for `prisma migrate`
DIRECT_URL="postgresql://postgres.xxxx:password@aws-0-region.pooler.supabase.com:5432/postgres"

# Anthropic API key, used server-side only for AI meal recognition / insights (Phase 2)
ANTHROPIC_API_KEY=""

# USDA FoodData Central API key (free, register at fdc.nal.usda.gov)
USDA_API_KEY=""
