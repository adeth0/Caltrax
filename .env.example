# PostgreSQL — pooled connection (use this one at runtime; Neon/Vercel Postgres
# give you this as the "pooled"/"pgbouncer" connection string)
DATABASE_URL="postgresql://user:password@host/caltrax?sslmode=require&pgbouncer=true"

# PostgreSQL — direct/unpooled connection, used only for `prisma migrate`
DIRECT_URL="postgresql://user:password@host/caltrax?sslmode=require"

# Session/auth secret (generate with: openssl rand -base64 32)
AUTH_SECRET=""

# Anthropic API key, used server-side only for AI meal recognition / insights (Phase 2)
ANTHROPIC_API_KEY=""

# USDA FoodData Central API key (free, register at fdc.nal.usda.gov)
USDA_API_KEY=""
