# Supabase project settings — Project Settings > API Keys in the Supabase dashboard.
# Current key format: publishable (client-safe) and secret (server-only),
# replacing the legacy anon/service_role naming.
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
# Server-only — never prefix with NEXT_PUBLIC_, never sent to the browser.
SUPABASE_SECRET_KEY="sb_secret_..."

# PostgreSQL — pooled connection (Supabase "Transaction" pooler, port 6543).
# Project Settings > Database > Connection string in the Supabase dashboard.
DATABASE_URL="postgresql://postgres.xxxx:password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"

# PostgreSQL — direct/unpooled connection (port 5432), used only for `prisma migrate`
DIRECT_URL="postgresql://postgres.xxxx:password@aws-0-region.pooler.supabase.com:5432/postgres"

# Anthropic API key, used server-side only for AI meal recognition / insights (Phase 2)
ANTHROPIC_API_KEY=""

# USDA FoodData Central API key (free, register at fdc.nal.usda.gov)
USDA_API_KEY=""

# Web Push (reminders). Generate a pair with:
#   npx web-push generate-vapid-keys
# Public key is exposed to the browser (needed for pushManager.subscribe);
# private key is server-only and must never be committed or exposed client-side.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
# mailto: or https: URL identifying who's sending the push, per the Web Push spec.
VAPID_SUBJECT="https://caltrax.kavauralabs.com"

# Shared secret for the /api/cron/reminders endpoint. Vercel Hobby's cron
# scheduler is limited to once/day, so this project calls that route from a
# free external scheduler (e.g. cron-job.org) every 5-15 min instead — set
# the same value here and as that scheduler's Authorization: Bearer header.
# Generate one with: node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
CRON_SECRET=""
