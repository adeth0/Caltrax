// Caltrax database schema (PostgreSQL via Supabase)
//
// Identity/auth lives in Supabase's own `auth.users` table (managed by
// Supabase Auth, not Prisma). Every app table below keys off that user's
// UUID as a plain string column — there is no app-level `User` model to
// keep in sync with it.
//
// Phase 1 covers: profile, goal engine inputs, food database cache, meal
// logging, weight/water logs, reminders. Phase 2+ adds recipes, planner,
// reminders detail, achievements, and wearable-sync tables (stubbed at
// bottom).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooled connection string (Supabase's "Transaction" pooler on port 6543) — used at runtime.
  url       = env("DATABASE_URL")
  // Direct (unpooled) connection (port 5432) — used only for migrations.
  directUrl = env("DIRECT_URL")
}

enum Sex {
  MALE
  FEMALE
}

enum ActivityLevel {
  SEDENTARY
  LIGHT
  MODERATE
  ACTIVE
  VERY_ACTIVE
}

enum PrimaryGoal {
  LOSE_FAT
  BUILD_MUSCLE
  MAINTAIN_WEIGHT
  IMPROVE_HEALTH
  INCREASE_PROTEIN
  ATHLETIC_PERFORMANCE
  BODY_RECOMPOSITION
}

enum DietaryPreference {
  NONE
  VEGETARIAN
  VEGAN
  KETO
  LOW_CARB
  MEDITERRANEAN
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}

enum FoodSource {
  OPEN_FOOD_FACTS
  USDA
  CUSTOM
}

/// One row per Supabase-authenticated user. `id` is that user's
/// `auth.users.id` (a UUID string) — set explicitly at creation time,
/// never auto-generated, so it always matches the Supabase session.
model Profile {
  id                  String            @id
  name                String?
  sex                 Sex
  age                 Int
  heightCm            Float
  weightKg            Float
  targetWeightKg      Float?
  activityLevel       ActivityLevel
  primaryGoal         PrimaryGoal
  targetRateKgPerWeek Float?
  dietaryPreference   DietaryPreference @default(NONE)
  allergies           String[]          @default([])

  weightUnit          String            @default("kg")
  heightUnit          String            @default("cm")
  volumeUnit          String            @default("ml")

  dailyWaterGoalMl     Int?
  notificationsEnabled Boolean          @default(true)

  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  mealEntries         MealEntry[]
  weightLogs          WeightLog[]
  waterLogs           WaterLog[]
  customFoods         Food[]
  reminders           Reminder[]
  recipes             Recipe[]
  favourites          Favourite[]

  @@map("profiles")
}

/// Cached/normalised food records, whether pulled from Open Food Facts,
/// USDA FoodData Central, or entered manually by a user.
model Food {
  id                  String     @id @default(cuid())
  source              FoodSource
  sourceId            String
  name                String
  brand               String?
  category            String?
  barcode             String?
  servingSizeG        Float?
  servingSizeLabel    String?

  caloriesPer100g     Float
  proteinPer100g      Float
  carbsPer100g        Float
  fatPer100g          Float
  fibrePer100g        Float?
  sugarPer100g        Float?
  saturatedFatPer100g Float?
  sodiumMgPer100g     Float?
  potassiumMgPer100g  Float?
  vitaminAPer100g     Float?
  vitaminCPer100g     Float?
  vitaminDPer100g     Float?
  vitaminEPer100g     Float?
  vitaminKPer100g     Float?
  calciumMgPer100g    Float?
  ironMgPer100g       Float?
  magnesiumMgPer100g  Float?
  zincMgPer100g       Float?

  imageUrl            String?

  ownerId             String?
  owner               Profile?   @relation(fields: [ownerId], references: [id])

  createdAt           DateTime   @default(now())

  mealEntries         MealEntry[]
  recipeItems         RecipeItem[]
  favouritedBy        Favourite[]

  @@unique([source, sourceId])
  @@index([barcode])
  @@map("foods")
}

model MealEntry {
  id              String   @id @default(cuid())
  userId          String
  user            Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  foodId          String
  food            Food     @relation(fields: [foodId], references: [id])

  mealType        MealType
  servingQuantity Float
  servingUnitG    Float

  loggedAt        DateTime @default(now())
  createdAt       DateTime @default(now())

  @@index([userId, loggedAt])
  @@map("meal_entries")
}

model WeightLog {
  id         String   @id @default(cuid())
  userId     String
  user       Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  weightKg   Float
  bodyFatPct Float?
  loggedAt   DateTime @default(now())

  @@index([userId, loggedAt])
  @@map("weight_logs")
}

model WaterLog {
  id       String   @id @default(cuid())
  userId   String
  user     Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  amountMl Int
  loggedAt DateTime @default(now())

  @@index([userId, loggedAt])
  @@map("water_logs")
}

model Reminder {
  id     String  @id @default(cuid())
  userId String
  user   Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  type   String  // "meal" | "water" | "exercise" | "weight_check" | "supplement" | "custom"
  label  String
  time   String  // "HH:mm" local time
  active Boolean @default(true)

  @@map("reminders")
}

// ---------------------------------------------------------------------
// Phase 3 (slice 1): recipes and favourites/quick-add.
// "Recent foods" needs no table of its own — it's derived from MealEntry
// history (distinct foods ordered by loggedAt) at query time.
// ---------------------------------------------------------------------

/// A user-defined bundle of foods that can be logged as a group. Logging a
/// recipe writes one MealEntry per RecipeItem (scaled by servings eaten) —
/// there's no separate "recipe entry" concept, so existing daily-total
/// aggregation (which just sums MealEntry+Food) needs no changes.
model Recipe {
  id        String       @id @default(cuid())
  userId    String
  user      Profile      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  servings  Float        @default(1)
  createdAt DateTime     @default(now())
  items     RecipeItem[]

  @@index([userId])
  @@map("recipes")
}

model RecipeItem {
  id       String @id @default(cuid())
  recipeId String
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  foodId   String
  food     Food   @relation(fields: [foodId], references: [id])
  /// Grams of this food in the WHOLE recipe (i.e. across all `Recipe.servings`), not per serving.
  grams    Float

  @@index([recipeId])
  @@map("recipe_items")
}

model Favourite {
  id        String   @id @default(cuid())
  userId    String
  user      Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  foodId    String
  food      Food     @relation(fields: [foodId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, foodId])
  @@map("favourites")
}

// ---------------------------------------------------------------------
// Phase 3+ tables still pending (meal planner, full micronutrient
// tracking, reminders detail, achievements, wearable sync) are
// intentionally left out here to keep each migration small and
// reviewable — add them as their own migration when scheduled.
// ---------------------------------------------------------------------
