// Caltrax database schema (PostgreSQL via Supabase)
//
// Identity/auth lives in Supabase's own `auth.users` table (managed by
// Supabase Auth, not Prisma). Every app table below keys off that user's
// UUID as a plain string column — there is no app-level `User` model to
// keep in sync with it.
//
// Phase 1 covers: profile, goal engine inputs, food database cache, meal
// logging, weight/water logs, reminders. Phase 2+ adds recipes, planner,
// reminders detail, achievements, and wearable-sync tables (stubbed at
// bottom).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooled connection string (Supabase's "Transaction" pooler on port 6543) — used at runtime.
  url       = env("DATABASE_URL")
  // Direct (unpooled) connection (port 5432) — used only for migrations.
  directUrl = env("DIRECT_URL")
}

enum Sex {
  MALE
  FEMALE
}

enum ActivityLevel {
  SEDENTARY
  LIGHT
  MODERATE
  ACTIVE
  VERY_ACTIVE
}

enum PrimaryGoal {
  LOSE_FAT
  BUILD_MUSCLE
  MAINTAIN_WEIGHT
  IMPROVE_HEALTH
  INCREASE_PROTEIN
  ATHLETIC_PERFORMANCE
  BODY_RECOMPOSITION
}

enum DietaryPreference {
  NONE
  VEGETARIAN
  VEGAN
  KETO
  LOW_CARB
  MEDITERRANEAN
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}

enum FoodSource {
  OPEN_FOOD_FACTS
  USDA
  CUSTOM
}

/// One row per Supabase-authenticated user. `id` is that user's
/// `auth.users.id` (a UUID string) — set explicitly at creation time,
/// never auto-generated, so it always matches the Supabase session.
model Profile {
  id                  String            @id
  name                String?
  sex                 Sex
  age                 Int
  heightCm            Float
  weightKg            Float
  targetWeightKg      Float?
  activityLevel       ActivityLevel
  primaryGoal         PrimaryGoal
  targetRateKgPerWeek Float?
  dietaryPreference   DietaryPreference @default(NONE)
  allergies           String[]          @default([])

  weightUnit          String            @default("kg")
  heightUnit          String            @default("cm")
  volumeUnit          String            @default("ml")

  dailyWaterGoalMl     Int?
  notificationsEnabled Boolean          @default(true)
  /// IANA timezone (e.g. "Europe/London") — needed so reminder times ("HH:mm")
  /// fire at the right moment for this user, not server time. Defaults to UTC
  /// until the client detects and saves the real one (see settings).
  timezone             String           @default("UTC")

  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  mealEntries         MealEntry[]
  weightLogs          WeightLog[]
  waterLogs           WaterLog[]
  customFoods         Food[]
  reminders           Reminder[]
  recipes             Recipe[]
  favourites          Favourite[]
  plannedMeals        PlannedMeal[]
  pushSubscriptions   PushSubscription[]
  unlockedAchievements UnlockedAchievement[]

  @@map("profiles")
}

/// Cached/normalised food records, whether pulled from Open Food Facts,
/// USDA FoodData Central, or entered manually by a user.
model Food {
  id                  String     @id @default(cuid())
  source              FoodSource
  sourceId            String
  name                String
  brand               String?
  category            String?
  barcode             String?
  servingSizeG        Float?
  servingSizeLabel    String?

  caloriesPer100g     Float
  proteinPer100g      Float
  carbsPer100g        Float
  fatPer100g          Float
  fibrePer100g        Float?
  sugarPer100g        Float?
  saturatedFatPer100g Float?
  sodiumMgPer100g     Float?
  potassiumMgPer100g  Float?
  vitaminAPer100g     Float?
  vitaminCPer100g     Float?
  vitaminDPer100g     Float?
  vitaminEPer100g     Float?
  vitaminKPer100g     Float?
  calciumMgPer100g    Float?
  ironMgPer100g       Float?
  magnesiumMgPer100g  Float?
  zincMgPer100g       Float?

  imageUrl            String?

  ownerId             String?
  owner               Profile?   @relation(fields: [ownerId], references: [id])

  createdAt           DateTime   @default(now())

  mealEntries         MealEntry[]
  recipeItems         RecipeItem[]
  favouritedBy        Favourite[]
  plannedMeals        PlannedMeal[]

  @@unique([source, sourceId])
  @@index([barcode])
  @@map("foods")
}

model MealEntry {
  id              String   @id @default(cuid())
  userId          String
  user            Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  foodId          String
  food            Food     @relation(fields: [foodId], references: [id])

  mealType        MealType
  servingQuantity Float
  servingUnitG    Float

  loggedAt        DateTime @default(now())
  createdAt       DateTime @default(now())

  @@index([userId, loggedAt])
  @@map("meal_entries")
}

model WeightLog {
  id         String   @id @default(cuid())
  userId     String
  user       Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  weightKg   Float
  bodyFatPct Float?
  loggedAt   DateTime @default(now())

  @@index([userId, loggedAt])
  @@map("weight_logs")
}

model WaterLog {
  id       String   @id @default(cuid())
  userId   String
  user     Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  amountMl Int
  loggedAt DateTime @default(now())

  @@index([userId, loggedAt])
  @@map("water_logs")
}

model Reminder {
  id          String    @id @default(cuid())
  userId      String
  user        Profile   @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String  // "meal" | "water" | "exercise" | "weight_check" | "supplement" | "custom"
  label       String
  time        String  // "HH:mm" local time
  active      Boolean   @default(true)
  /// Set by the reminders cron after a successful send, compared against
  /// "today" in the user's timezone so a reminder never fires twice in one day
  /// even if the cron window overlaps its target time on two consecutive runs.
  lastFiredAt DateTime?

  @@index([active, time])
  @@map("reminders")
}

/// A browser's Web Push subscription (one per device/browser a user has
/// enabled notifications on). endpoint is unique because re-subscribing
/// the same browser reissues the same endpoint — upsert on it rather than
/// accumulating duplicates.
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("push_subscriptions")
}

// ---------------------------------------------------------------------
// Phase 3 (slice 1): recipes and favourites/quick-add.
// "Recent foods" needs no table of its own — it's derived from MealEntry
// history (distinct foods ordered by loggedAt) at query time.
// ---------------------------------------------------------------------

/// A user-defined bundle of foods that can be logged as a group. Logging a
/// recipe writes one MealEntry per RecipeItem (scaled by servings eaten) —
/// there's no separate "recipe entry" concept, so existing daily-total
/// aggregation (which just sums MealEntry+Food) needs no changes.
model Recipe {
  id        String       @id @default(cuid())
  userId    String
  user      Profile      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  servings  Float        @default(1)
  createdAt DateTime     @default(now())
  items     RecipeItem[]
  plannedMeals PlannedMeal[]

  @@index([userId])
  @@map("recipes")
}

model RecipeItem {
  id       String @id @default(cuid())
  recipeId String
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  foodId   String
  food     Food   @relation(fields: [foodId], references: [id])
  /// Grams of this food in the WHOLE recipe (i.e. across all `Recipe.servings`), not per serving.
  grams    Float

  @@index([recipeId])
  @@map("recipe_items")
}

model Favourite {
  id        String   @id @default(cuid())
  userId    String
  user      Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  foodId    String
  food      Food     @relation(fields: [foodId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, foodId])
  @@map("favourites")
}

// ---------------------------------------------------------------------
// Weekly meal planner. A PlannedMeal is intent, not a log entry — it only
// becomes real data (a MealEntry) when the user marks it eaten, via the
// same logMealAction/logRecipeAction paths used elsewhere. Exactly one of
// foodId/recipeId is set (enforced by a CHECK constraint in the migration,
// since Prisma's schema language has no native XOR-column construct).
// ---------------------------------------------------------------------
model PlannedMeal {
  id       String    @id @default(cuid())
  userId   String
  user     Profile   @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Date-only (stored at UTC midnight) — the calendar day this meal is planned for.
  date     DateTime  @db.Date
  mealType MealType

  foodId        String?
  food          Food?   @relation(fields: [foodId], references: [id], onDelete: Cascade)
  servingGrams  Float?

  recipeId      String?
  recipe        Recipe? @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  servingsCount Float?

  notes     String?
  createdAt DateTime @default(now())

  @@index([userId, date])
  @@map("planned_meals")
}

// ---------------------------------------------------------------------
// Achievements/badges. Definitions (label, description, icon, unlock
// criteria) live in code (src/lib/achievements.ts), not the database —
// this table only records the fact and moment a given user met one.
// Persisted (rather than recomputed live) so streak-based badges stay
// unlocked even if the streak later breaks.
// ---------------------------------------------------------------------
model UnlockedAchievement {
  id         String   @id @default(cuid())
  userId     String
  user       Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Matches an id in the ACHIEVEMENTS array in src/lib/achievements.ts.
  key        String
  unlockedAt DateTime @default(now())

  @@unique([userId, key])
  @@map("unlocked_achievements")
}

